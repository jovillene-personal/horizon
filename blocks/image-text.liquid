

<div class="image-text">
{% if section.settings.image %}
  <img src="{{ section.settings.image | image_url }}" height="auto" width="100%" alt="{{ section.settings.heading }}">
{% endif %}
{% if section.settings.text %}
  <p>{{ section.settings.text }}</p>
{% endif %}
</div>

{% schema %}
{
    "name": "Image Text",
    "settings": [
        {
            "type": "image_picker",
            "id": "image",
            "label": "Image"
        },
        {
            "type": "text",
            "id": "heading",
            "label": "Heading",
            "default": "Heading"
        },
        ],
    "presets": [
        {
            "name": "Image Text",
            "category": "Custom"
        },
    ]
}
{% endschema %}
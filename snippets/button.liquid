{%- doc -%}
  Intended for use in a block similar to the button block.

  @param {string} link - link to render
  @param {object} [block] - The block

  @example
  {% render 'button', link: '/collections/all' %}
{%- enddoc -%}

{% assign block_settings = block.settings %}

{%  style  %} 
  {% if block_settings.dev_custom_width %}
    .button--custom-width {
      max-width: 407px;
      border-radius: 5px;
      font-family: Montserrat;
      font-weight: 600;
      font-size: 18px;
      line-height: 23.8px;
      letter-spacing: 0%;
      text-align: center;
      display: flex;
      justify-content: center;
      gap: 10px;
      height: 62px;
      align-items: center;
    }
  {% endif %}

  .button-image-wrapper {
    max-width: 100px;
  }
  .button__image {
    object-fit: cover;
  }
{% endstyle %} 

<a
  {% if link == blank %}
    role="link"
    aria-disabled="true"
  {% else %}
    href="{{ link }}"
  {% endif %}
  class="
    size-style
    {% if block_settings.dev_custom_width %}
      button--custom-width
    {% endif %}
    {{ block_settings.style_class }}
    {{ block_settings.style_class }}--{{ block.id }}
  "
  style="{% render 'size-style', settings: block_settings %}"
  {%- if block_settings.open_in_new_tab -%}
    target="_blank"
    rel="noopener noreferrer"
  {%- endif -%}
  {{ block.shopify_attributes }}
>
  {{ block_settings.label }}
  {% if block_settings.image != blank %}
    <div class="button-image-wrapper">
      <img src="{{ block_settings.image | image_url }}" width="100%" height="auto" alt="" class="button__image" />
    </div>
  {% endif %}
</a>

{% stylesheet %}
  .link {
    text-decoration: none;
    text-decoration-color: currentcolor;

    &:hover {
      color: var(--color-primary-hover);
      text-decoration-color: transparent;
    }
  }
{% endstylesheet %}
